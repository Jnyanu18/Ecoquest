
{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Production-grade student/teacher profile with stats.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "schoolId": { "type": "string" },
        "ecoPoints": { "type": "number", "default": 0 },
        "level": { "type": "number", "default": 1 },
        "streak": { "type": "number", "default": 0 },
        "badges": { "type": "array", "items": { "type": "string" } },
        "totalCO2Saved": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role", "schoolId"]
    },
    "School": {
      "title": "Institutional Hub",
      "description": "School aggregate impact and basic info.",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "totalPoints": { "type": "number", "default": 0 },
        "totalCO2Reduced": { "type": "number", "default": 0 },
        "totalPlasticReduced": { "type": "number", "default": 0 },
        "totalTrees": { "type": "number", "default": 0 }
      }
    },
    "Mission": {
      "title": "Eco Mission",
      "description": "Tasks created for students with measurable impact.",
      "type": "object",
      "properties": {
        "missionId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "points": { "type": "number" },
        "impactType": { "type": "string", "enum": ["co2", "plastic", "trees", "water"] },
        "impactValue": { "type": "number" },
        "schoolId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "createdBy": { "type": "string" }
      }
    },
    "Submission": {
      "title": "Mission Proof",
      "description": "Student proof for verified task completion.",
      "type": "object",
      "properties": {
        "missionId": { "type": "string" },
        "studentId": { "type": "string" },
        "schoolId": { "type": "string" },
        "proofUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "feedback": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "verifiedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CarbonReport": {
      "title": "Carbon Audit",
      "description": "Detailed monthly carbon calculation data.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "month": { "type": "string" },
        "carKM": { "type": "number" },
        "busKM": { "type": "number" },
        "electricityKWh": { "type": "number" },
        "dietType": { "type": "string", "enum": ["VEG", "MIXED", "NON_VEG"] },
        "totalCO2": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Student and teacher profiles."
    },
    "/schools/{schoolId}": {
      "schema": "School",
      "description": "School aggregate impact metrics."
    },
    "/missions/{missionId}": {
      "schema": "Mission",
      "description": "Platform-wide and school-specific tasks."
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Verified student activities."
    },
    "/carbonReports/{reportId}": {
      "schema": "CarbonReport",
      "description": "Historical carbon footprint data."
    },
    "/leaderboards/{schoolId}": {
      "schema": { "type": "object", "properties": { "rankings": { "type": "array" } } },
      "description": "Aggregated leaderboard data."
    }
  }
}
